{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "lib": [
      "ES2020"
    ],
    "types": [
      "node"
    ],
    "noEmit": false,
    "moduleResolution": "Node",
    "baseUrl": ".",
    "paths": {
      "@starbuds/shared": [
        "../shared/src/index"
      ],
      "@starbuds/shared/*": [
        "../shared/src/*"
      ]
    }
  },
  "include": [
    "src"
  ]
}
